{
  "entities": {
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "maxLength": 200 },
        "description": { "type": "string", "maxLength": 2000 },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string", "maxLength": 100 },
        "createdAt": { "type": "string", "format": "date-time" },
        "questions": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "number" },
              "explanation": { "type": "string" }
            }
          }
        },
        "isPublic": { "type": "boolean" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "timePerQuestion": { "type": "number", "minimum": 5, "maximum": 300 }
      },
      "required": ["title", "creatorId", "questions", "difficulty", "timePerQuestion"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "QuizAttempt": {
      "title": "Quiz Attempt",
      "description": "A user's attempt at a quiz",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "quizId": { "type": "string" },
        "quizTitle": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "quizId", "quizTitle", "score", "totalQuestions", "completedAt"]
    }
  },
  "firestore": {
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of quizzes"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/attempts/{attemptId}": {
      "schema": "QuizAttempt",
      "description": "Collection of quiz attempts"
    }
  }
}
